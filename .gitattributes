# Auto detect text files and normalize to LF
* text=auto eol=lf

# Source code
*.rs text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Shell scripts (must use LF)
*.sh text eol=lf
*.bash text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Config files
*.conf text eol=lf
*.cfg text eol=lf
*.example text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Binary files (no normalization)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.rpm binary